# Master CRM Bot configuration

# Telegram bot tokens (get from @BotFather)
MASTER_BOT_TOKEN=
CLIENT_BOT_TOKEN=

# Client bot username (without @)
CLIENT_BOT_USERNAME=
MASTER_BOT_USERNAME=

# Database URL
# SQLite (development): sqlite:///db.sqlite3
# PostgreSQL (production): postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///db.sqlite3

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Encryption key for sensitive data (phone, name, birthday, Google credentials)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Google Calendar integration (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
OAUTH_SERVER_PORT=8090

# Mini App API
API_PORT=8081
MINIAPP_URL=https://app.crmfit.ru
APP_ENV=production
